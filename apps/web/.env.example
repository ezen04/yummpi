# apps/web (Next.js) 환경변수 템플릿
# 키 이름만 등록 — 실제 값은 절대 커밋하지 않는다. 값은 팀 공유 채널로 전달.
# 로컬 실제 값은 apps/web/.env.local 에 채운다(git 무시 대상).
#
# Next.js는 모노레포 루트 .env 를 자동 로드하지 않는다 → web 런타임이 쓰는 값은
# 반드시 이 앱 폴더(.env.local / .env)에 있어야 주입된다.

# ── DB (Prisma Client는 DATABASE_URL을 env에서 암묵적으로 읽음) ──────────────
DATABASE_URL=

# ── 인증 (NextAuth Kakao + DB 세션) ────────────────────────────────────────
# NEXTAUTH_URL: 배포 도메인(개발은 http://localhost:3000)
# NextAuth 베이스 URL (= 초대 링크 도메인 기준)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
# 게스트 서명 토큰 시크릿. 미설정 시 NEXTAUTH_SECRET로 폴백.
GUEST_TOKEN_SECRET=
# 세션·게스트 쿠키 상위 도메인. 서브도메인(ws.yummpi.com) 소켓 핸드셰이크용(aws-vercel.md §16.3).
# Vercel Production에만 '.yummpi.com' 설정 — 로컬/Preview는 반드시 비운다(비우면 host-only).
COOKIE_DOMAIN=

# ── 카카오 Local REST (장소 검색 서버 프록시 — 서버 전용, 클라 노출 금지) ──────
KAKAO_REST_API_KEY=

# ── CLOVA General OCR V2 (서버 전용, import 'server-only'로 강제) ────────────
# NEXT_PUBLIC_ 접두사 금지 — 붙이면 클라 번들로 시크릿이 노출된다.
CLOVA_OCR_INVOKE_URL=
CLOVA_OCR_SECRET=

# ── Redis (Socket emitter · 송금 독촉 큐) ──────────────────────────────────
REDIS_URL=

# ── 클라이언트 노출 값 (NEXT_PUBLIC_*) ─────────────────────────────────────
# 빌드 시 번들에 포함되므로 시크릿(REST/Secret 키)은 절대 여기 두지 않는다.
NEXT_PUBLIC_KAKAO_MAP_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# 소켓 서버. 로컬=localhost, prod(Vercel)=https://ws.yummpi.com (aws-vercel.md §16)
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000


