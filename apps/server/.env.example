# Database (Docker: localhost:5433)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5433/DB_NAME

# Redis (Docker: localhost:6380)
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}

# Web Push (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Server
PORT=4000
CLIENT_ORIGIN=http://localhost:3000

# SMTP (Nodemailer)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
