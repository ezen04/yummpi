# PostgreSQL
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5433/${POSTGRES_DB}

# Redis
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}

# NextAuth
# NEXTAUTH_SECRET 생성: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Kakao OAuth (https://developers.kakao.com)
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# Kakao API
KAKAO_REST_API_KEY=

# 게스트 토큰 서명 키 (b안). 미설정 시 NEXTAUTH_SECRET으로 fallback.
# 생성: openssl rand -base64 32
GUEST_TOKEN_SECRET=
