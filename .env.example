# PostgreSQL
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5433/${POSTGRES_DB}

# Redis
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}

# NextAuth
# NEXTAUTH_SECRET 생성: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Kakao OAuth (https://developers.kakao.com)
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# Kakao API
KAKAO_REST_API_KEY=

# 게스트 토큰 서명 키 (b안). 미설정 시 NEXTAUTH_SECRET으로 fallback.
# 생성: openssl rand -base64 32
GUEST_TOKEN_SECRET=

# Web Push (VAPID) — 클라이언트 공개 키만 노출
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# CLOVA OCR (https://www.ncloud.com/product/aiService/ocr)
# CLOVA OCR 도메인의 Invoke URL과 Secret. 서버 전용 — 클라이언트 노출 금지.
CLOVA_OCR_INVOKE_URL=
CLOVA_OCR_SECRET=

# Kakao Map (브라우저 노출)
NEXT_PUBLIC_KAKAO_MAP_KEY=

# Socket 서버 URL (브라우저 노출)
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

# SMTP (메일 전송)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

# AWS S3 (영수증 이미지 저장 · presigned URL). 서버 전용 — 클라이언트 노출 금지.
# 운영(Fargate)은 task role로 자격증명 자동 주입 → ACCESS_KEY 불필요.
# 로컬 개발에서 presigned 테스트 시에만 ACCESS_KEY 사용.
AWS_REGION=
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=