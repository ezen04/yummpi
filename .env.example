# ───────── 공통 / 인프라 ─────────
NODE_ENV=development

# PostgreSQL 17 (docker-compose)
POSTGRES_USER=gatherflow
POSTGRES_PASSWORD=gatherflow
POSTGRES_DB=gatherflow
DATABASE_URL=postgresql://gatherflow:gatherflow@localhost:5432/gatherflow?schema=public

# Redis 8 (Socket.io adapter · BullMQ)
REDIS_URL=redis://localhost:6379

# ───────── 인증 (① 모임·인증 리드) ─────────
# NextAuth(Auth.js v5) ↔ NestJS JWT 가 같은 시크릿을 공유해야 함
AUTH_SECRET=change-me-shared-between-web-and-api
JWT_SECRET=change-me-shared-between-web-and-api
JWT_EXPIRES_IN=7d

# ───────── 웹 (apps/web) ─────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
NEXT_PUBLIC_KAKAO_JS_KEY=your-kakao-javascript-key

# ───────── 장소·지도 (② 장소·지도) ─────────
KAKAO_REST_API_KEY=your-kakao-rest-api-key
# V2 보조 (대중교통 이동시간)
ODSAY_API_KEY=
TMAP_API_KEY=

# ───────── 정산 (④ 정산) ─────────
# CLOVA OCR (권장) — 영수증 메뉴 추출
CLOVA_OCR_INVOKE_URL=
CLOVA_OCR_SECRET_KEY=

# ───────── 미디어 / 메일 (⑤ 인프라·공통) ─────────
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=gatherflow-media
CLOUDFRONT_URL=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="GatherFlow <no-reply@gatherflow.app>"
