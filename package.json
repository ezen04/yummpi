{
  "name": "gatherflow",
  "private": true,
  "version": "0.1.0",
  "description": "모임 장소 선정·투표·예약관리·정산을 한 흐름으로 묶는 그룹 모임 운영 플랫폼 (Next.js PWA + NestJS)",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "db:generate": "pnpm --filter @gatherflow/api prisma generate",
    "db:migrate": "pnpm --filter @gatherflow/api prisma migrate dev",
    "db:studio": "pnpm --filter @gatherflow/api prisma studio",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "turbo": "2.5.4",
    "typescript": "5.9.2",
    "prettier": "3.3.3",
    "@types/node": "24.0.3"
  },
  "pnpm": {
    "overrides": {
      "zod": "4.0.5"
    }
  }
}
