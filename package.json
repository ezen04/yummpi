{
  "name": "yummpi",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": "22.22.3",
    "pnpm": "10.11.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,css}\""
  },
  "devDependencies": {
    "prettier": "3.8.4",
    "turbo": "2.5.4",
    "typescript": "5.9.3"
  }
}
